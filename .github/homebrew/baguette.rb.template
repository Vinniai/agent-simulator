# typed: false
# frozen_string_literal: true

class AgentSim < Formula
  desc "Agent-driven iOS simulator control, capture, markup, and review"
  homepage "https://github.com/tddworks/baguette"
  version "__VERSION__"
  license "Apache-2.0"

  on_arm do
    url "https://github.com/tddworks/baguette/releases/download/__VERSION__/agent-sim___VERSION___macOS_arm64.tar.gz"
    sha256 "__SHA256_ARM64__"
  end

  depends_on :macos
  depends_on arch: :arm64
  depends_on xcode: ["26.0", :build]

  def install
    # Binary and its SPM resource bundle must sit side-by-side at
    # runtime — WebRoot resolves the bundle via dladdr from the
    # executable's directory. Install both into libexec and symlink
    # the binary into bin.
    libexec.install "agent-sim"
    libexec.install "Baguette_Baguette.bundle"
    bin.install_symlink libexec/"agent-sim"
  end

  def caveats
    <<~EOS
      agent-sim links against private SimulatorKit and CoreSimulator
      frameworks shipped with Xcode 26. Make sure Xcode 26 is installed
      and `xcode-select` points at it before running `agent-sim serve`.
    EOS
  end

  test do
    assert_match "agent-sim", shell_output("#{bin}/agent-sim --help")
  end
end
